# Hojokin Pocket staging example.
# Do not commit real AWS access keys or production customer-data settings.

APP_ENV=staging
NODE_ENV=production
API_PORT=8787

# Default stays free and deterministic. Change to "bedrock" only after AWS Budget
# alarms are configured and the model is enabled in Amazon Bedrock.
LLM_PROVIDER=local

# Bedrock Claude settings for staging/closed-beta trials.
# LLM_PROVIDER=bedrock
AWS_REGION=ap-northeast-1
BEDROCK_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20241022-v2:0
# Optional lower-cost connectivity check model used by npm run bedrock:smoke.
BEDROCK_SMOKE_MODEL_ID=apac.anthropic.claude-3-haiku-20240307-v1:0

# Local-only Claude Code/Agent SDK unblocker. Do not use this in shared staging
# or production servers because it depends on the local user's Claude login.
# LLM_PROVIDER=claude_cli
# CLAUDE_CLI_MODEL=haiku
# CLAUDE_CLI_PROMPT_MODE=compact
# CLAUDE_CLI_TIMEOUT_MS=120000

# App-side LLM cost guardrails. These are soft caps inside the app and should be
# paired with AWS Budgets for account-level alerts.
LLM_DAILY_BUDGET_USD=5
LLM_MONTHLY_BUDGET_USD=50
LLM_MAX_REQUEST_USD=0.25
LLM_MAX_OUTPUT_TOKENS=2200
LLM_MAX_INPUT_CHARS=18000

# Optional: persist LLM usage logs somewhere durable in the staging runtime.
# LLM_USAGE_LEDGER_PATH=/app/data/runtime/llm-usage.jsonl
