{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/data/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/patterns/**",
              "ui_kits/hojokin-pocket/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Noto Sans JP))/i]",
        "message": "Font not provided by the design system. Available: Noto Sans JP."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnimatedNumber'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|format|decimals|duration|from|prefix|suffix|variant|cycles|style|key|ref|className|style|children)$/]",
        "message": "<AnimatedNumber> doesn't accept that prop. Declared props: value, format, decimals, duration, from, prefix, suffix, variant, cycles, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnimatedNumber'] > JSXAttribute[name.name='format'] > Literal[value!=/^(?:plain|comma|yen|percent)$/]",
        "message": "<AnimatedNumber> format must be one of 'plain' | 'comma' | 'yen' | 'percent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnimatedNumber'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:count|slot)$/]",
        "message": "<AnimatedNumber> variant must be one of 'count' | 'slot'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:solid|outline|brand-tint|success|warning|danger|neutral)$/]",
        "message": "<Badge> tone must be one of 'solid' | 'outline' | 'brand-tint' | 'success' | 'warning' | 'danger' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|loading|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, loading, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|title|subtitle|variant|tappable|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, title, subtitle, variant, tappable, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|highlight)$/]",
        "message": "<Card> variant must be one of 'default' | 'highlight'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|from|variant|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: children, from, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='from'] > Literal[value!=/^(?:me|them)$/]",
        "message": "<ChatBubble> from must be one of 'me' | 'them'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:system)$/]",
        "message": "<ChatBubble> variant must be one of 'system'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|aiTag|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, aiTag, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|hint|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: title, hint, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|type|error|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, value, onChange, placeholder, type, error, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|left|right|onLeft|onRight|brand|noBorder|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: title, left, right, onLeft, onRight, brand, noBorder."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhoneFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|statusBar|width|height|style|key|ref|className|style|children)$/]",
        "message": "<PhoneFrame> doesn't accept that prop. Declared props: children, statusBar, width, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|stroke|style|key|ref|className|style|children)$/]",
        "message": "<Spinner> doesn't accept that prop. Declared props: size, stroke, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:k|v|key|ref|className|style|children)$/]",
        "message": "<StatItem> doesn't accept that prop. Declared props: k, v."
      },
      {
        "selector": "JSXOpeningElement[name.name='SubsidyMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<SubsidyMeta> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|sub|state|key|ref|className|style|children)$/]",
        "message": "<TimelineItem> doesn't accept that prop. Declared props: title, sub, state."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineItem'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:done|active|todo)$/]",
        "message": "<TimelineItem> state must be one of 'done' | 'active' | 'todo'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
